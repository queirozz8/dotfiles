configuration {
    modi:           "drun,run,window";
    show-icons:     true;
    icon-theme:     "Papirus-Dark";
    terminal:       "kitty";
    drun-display-format: "{name}";
    display-drun:   " Apps";
    display-run:    " Run";
    display-window: " Windows";
    font:           "JetBrains Mono 11";
}

@theme "~/.config/rofi/themes/vesper.rasi"
